#!/bin/sh
# Custom configure script for mochiutils

# Terminal colors (disable if not a terminal)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    RESET='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi

# Default configurations
PREFIX="/usr"
BINDIR=""
SBINDIR=""
HOST=""
SYSROOT=""
CC="${CC:-gcc}"
CFLAGS="${CFLAGS:--Wall -O2}"
LDFLAGS="${LDFLAGS:-}"
ENABLE_DEBUG=0

# Function to print usage
show_help() {
    echo "Usage: $0 [OPTION]..."
    echo ""
    echo "Defaults for the options are specified in brackets."
    echo ""
    echo "Installation directories:"
    echo "  --prefix=PREFIX         install architecture-independent files in PREFIX [/usr]"
    echo "  --bindir=DIR            user executables [PREFIX/bin]"
    echo "  --sbindir=DIR           system admin executables [PREFIX/sbin]"
    echo ""
    echo "System types:"
    echo "  --host=HOST             cross-compile to build programs to run on HOST [guessed]"
    echo ""
    echo "Optional Features:"
    echo "  --enable-debug          build with debug symbols (-g -O0 -DDEBUG)"
    echo "  --disable-debug         build with optimization (default)"
    echo ""
    echo "Optional Packages:"
    echo "  --with-sysroot=DIR      search for dependent libraries within DIR (or compiler's sysroot if not specified)"
    echo ""
    echo "Some influential environment variables:"
    echo "  CC          C compiler command"
    echo "  CFLAGS      C compiler flags"
    echo "  LDFLAGS     linker flags, e.g. -L<lib dir> if you have libraries in a nonstandard directory <lib dir>"
    echo ""
}

# Parse command-line arguments
for arg in "$@"; do
    case "$arg" in
        --help|-h)
            show_help
            exit 0
            ;;
        --host=*)
            HOST="${arg#*=}"
            ;;
        --with-sysroot=*)
            SYSROOT="${arg#*=}"
            ;;
        --prefix=*)
            PREFIX="${arg#*=}"
            ;;
        --bindir=*)
            BINDIR="${arg#*=}"
            ;;
        --sbindir=*)
            SBINDIR="${arg#*=}"
            ;;
        --enable-debug)
            ENABLE_DEBUG=1
            ;;
        --disable-debug)
            ENABLE_DEBUG=0
            ;;
        CC=*)
            CC="${arg#*=}"
            ;;
        CFLAGS=*)
            CFLAGS="${arg#*=}"
            ;;
        LDFLAGS=*)
            LDFLAGS="${arg#*=}"
            ;;
        *)
            printf "${YELLOW}Warning${RESET}: Unrecognized option '%s'\n" "$arg" >&2
            ;;
    esac
done

# Validate that PREFIX is an absolute path
case "$PREFIX" in
    /*) ;;
    *) printf "${RED}Error${RESET}: --prefix must be an absolute path (got: %s)\n" "$PREFIX" >&2; exit 1 ;;
esac

# Fill in default bindir / sbindir
BINDIR="${BINDIR:-$PREFIX/bin}"
SBINDIR="${SBINDIR:-$PREFIX/sbin}"

# If a cross-compiler host is provided and CC wasn't overridden, set CC to the cross compiler
if [ -n "$HOST" ]; then
    # Check if CC was passed as an argument explicitly
    has_cc=0
    for arg in "$@"; do
        case "$arg" in
            CC=*) has_cc=1 ;;
        esac
    done

    if [ "$has_cc" -eq 0 ]; then
        CC="${HOST}-gcc"
    fi
fi

# Detect host architecture when not cross-compiling
if [ -z "$HOST" ]; then
    ARCH=$(uname -m 2>/dev/null || echo "unknown")
else
    ARCH="$HOST"
fi

# Apply debug flags
if [ "$ENABLE_DEBUG" -eq 1 ]; then
    CFLAGS="$CFLAGS -g -O0 -DDEBUG"
fi

# If sysroot is provided, append it to CFLAGS and LDFLAGS
if [ -n "$SYSROOT" ]; then
    CFLAGS="$CFLAGS --sysroot=$SYSROOT"
    LDFLAGS="$LDFLAGS --sysroot=$SYSROOT"
fi

# Check if the C compiler is available
printf "Checking for C compiler (%s)... " "$CC"
if command -v "$CC" > /dev/null 2>&1; then
    CC_VERSION=$("$CC" --version 2>/dev/null | head -1)
    printf "${GREEN}found${RESET} (%s)\n" "$CC_VERSION"
else
    printf "${RED}not found${RESET}\n"
    printf "${RED}Error${RESET}: C compiler '%s' not found in PATH.\n" "$CC" >&2
    exit 1
fi

# Generate config.mk
printf "Generating config.mk...\n"
cat << EOF > config.mk
# Generated by configure
CC = $CC
HOST = $HOST
ARCH = $ARCH
SYSROOT = $SYSROOT
PREFIX = $PREFIX
BINDIR = $BINDIR
SBINDIR = $SBINDIR
CFLAGS = $CFLAGS
LDFLAGS = $LDFLAGS
EOF

# Generate config.h
printf "Generating config.h...\n"
cat << EOF > config.h
/* Generated by configure — do not edit */
#ifndef CONFIG_H
#define CONFIG_H

#define PACKAGE_NAME    "mochi-utils"
#define PACKAGE_VERSION "1.0"
#define PREFIX          "$PREFIX"
#define BINDIR          "$BINDIR"
#define SBINDIR         "$SBINDIR"
#define TARGET_ARCH     "$ARCH"

EOF

if [ "$ENABLE_DEBUG" -eq 1 ]; then
    printf '#define DEBUG 1\n' >> config.h
else
    printf '/* #undef DEBUG */\n' >> config.h
fi
printf '\n#endif /* CONFIG_H */\n' >> config.h

printf "\n${BOLD}Configuration complete!${RESET}\n"
printf "  ${CYAN}%-16s${RESET} %s\n" "Target Host:"   "${HOST:-<native>}"
printf "  ${CYAN}%-16s${RESET} %s\n" "Architecture:"  "$ARCH"
printf "  ${CYAN}%-16s${RESET} %s\n" "C Compiler:"    "$CC"
printf "  ${CYAN}%-16s${RESET} %s\n" "Sysroot:"       "${SYSROOT:-<default>}"
printf "  ${CYAN}%-16s${RESET} %s\n" "Prefix:"        "$PREFIX"
printf "  ${CYAN}%-16s${RESET} %s\n" "Bindir:"        "$BINDIR"
printf "  ${CYAN}%-16s${RESET} %s\n" "Sbindir:"       "$SBINDIR"
printf "  ${CYAN}%-16s${RESET} %s\n" "C Flags:"       "$CFLAGS"
printf "  ${CYAN}%-16s${RESET} %s\n" "Link Flags:"    "${LDFLAGS:--}"
printf "  ${CYAN}%-16s${RESET} %s\n" "Debug Build:"   "$([ "$ENABLE_DEBUG" -eq 1 ] && echo yes || echo no)"
printf "\nYou can now run 'make' to compile mochiutils.\n"
